EXPO_PUBLIC_APP_SERVER_URL=http://127.0.0.1:3001
APP_PUBLIC_SERVER_URL=http://127.0.0.1:3001
APP_SERVER_PORT=3001
# Keep this same on every computer if you move server/data/users.secure.db.
# If omitted in development, server/data/app-data.key is generated and must move with the DB.
APP_DATA_SECRET=change-me
# Optional custom location for the portable generated key.
# APP_DATA_KEY_FILE=server/data/app-data.key
ADMIN_EMAIL=admin@mobiluygulama.local
ADMIN_PASSWORD=change-me
CORS_ORIGINS=http://localhost:8081,http://localhost:8082
AUTH_RATE_LIMIT_MAX=30
SEARCH_RATE_LIMIT_MAX=80
USER_DATA_RATE_LIMIT_MAX=120
SEARCH_CACHE_LIMIT=700
GEMINI_MODEL=gemini-2.5-flash
# Put your real Gemini key in .env.local; this example stays empty on GitHub.
# Set to false if Google Search grounding is not available for your key.
GEMINI_API_KEY=AQ.Ab8RN6LjrPj0LPNyHoo1v65ZYg5rY3topt2IOvx73iKf15GObw
GEMINI_GOOGLE_SEARCH=true
SESSION_TTL_MS=86400000
FETCH_TIMEOUT_MS=30000
