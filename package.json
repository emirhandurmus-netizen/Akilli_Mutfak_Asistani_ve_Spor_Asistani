{
  "name": "mobiluygulama",
  "version": "0.0.1",
  "main": "index.ts",
  "scripts": {
    "postinstall": "cd server && npm install",
    "dev": "expo start --web --host localhost",
    "start": "expo start",
    "start:frontend": "expo start",
    "start:backend": "npm start --prefix server",
    "start:all": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:clean": "expo start -c",
    "start:lan": "expo start --lan",
    "start:tunnel": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start-phone.ps1 -Mode tunnel",
    "start:localhost": "expo start --host localhost",
    "android": "expo start --android",
    "android:clean": "expo start --android -c",
    "android:tunnel": "expo start --android --tunnel",
    "android:localhost": "expo start --android --host localhost",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:clean": "expo start --web -c",
    "web:mobile-view": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start-stack.ps1",
    "web:localhost": "expo start --web --host localhost",
    "server": "node .\\server\\index.js",
    "smoke:api": "node .\\scripts\\smoke-api.js",
    "smoke:ui": "playwright test scripts/ui-smoke.spec.js",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run smoke:api",
    "phone": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start-phone.ps1 -Mode lan",
    "phone:tunnel": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start-phone.ps1 -Mode tunnel",
    "phone:anywhere": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start-phone.ps1 -Mode tunnel",
    "phone:auto": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start-phone.ps1 -Mode lan -ClearCache",
    "phone:lan": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start-phone.ps1 -Mode lan",
    "phone:local": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start-phone.ps1 -Mode lan",
    "phone:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start-phone.ps1 -Mode lan -ClearCache",
    "legacy:broskos-redirect": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\start_broskos_current.ps1 -Mode web",
    "version:bump": "node .\\scripts\\bump-version.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^55.0.13",
    "expo-status-bar": "~3.0.9",
    "express": "^5.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@playwright/test": "^1.59.1",
    "@types/react": "~19.1.0",
    "concurrently": "^8.2.2",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20 <24"
  },
  "private": true
}
